#!/usr/bin/env bash

. "$HOME/.local/bin/webmenu-utils"

require_deps
load_config

command -v inotifywait >/dev/null 2>&1 || {
    echo "inotifywait manquant (paquet inotify-tools)."
    exit 1
}

echo "WebMenu daemon : surveillance de $WEBMENU_DB"
while inotifywait -e close_write "$WEBMENU_DB"; do
    "$HOME/.local/bin/webmenu" sync
done

