#!/usr/bin/env bash
set -euo pipefail
IFS=$'¥n¥t'

###############################################
#                CONSTANTES                   #
###############################################

WEBMENU_CONF_DIR="$HOME/.config/webmenu"
WEBMENU_DB="$WEBMENU_CONF_DIR/webmenu.json"
WEBMENU_CONFIG="$WEBMENU_CONF_DIR/config.json"
WEBMENU_TEMPLATES="$WEBMENU_CONF_DIR/templates"
WEBMENU_ICONS="$WEBMENU_CONF_DIR/share/icons"
WEBMENU_DESKTOP_DIR="$HOME/.local/share/applications/web-links"

mkdir -p "$WEBMENU_DESKTOP_DIR" "$WEBMENU_ICONS"

###############################################
#              Dﾃ臼ENDANCES                    #
###############################################

require_deps() {
    for cmd in jq zenity wget file; do
        command -v "$cmd" >/dev/null 2>&1 || {
            echo "Dﾃｩpendance manquante : $cmd"
            exit 1
        }
    done
}

###############################################
#              CHARGEMENT CONFIG              #
###############################################

load_config() {
    DEFAULT_BROWSER=$(jq -r '.default_browser // "firefox"' "$WEBMENU_CONFIG")
    TEMPLATE_FILE=$(jq -r '.template // "‾/.config/webmenu/templates/default.tpl"' "$WEBMENU_CONFIG")
    ICON_REFRESH_DAYS=$(jq -r '.icon_refresh_days // 7' "$WEBMENU_CONFIG")
    TEMPLATE_FILE="${TEMPLATE_FILE/#¥‾/$HOME}"
}

###############################################
#              JSON UTILITAIRES               #
###############################################

apply_json_patch() {
    local jq_filter="$1"
    local tmp
    tmp=$(mktemp)

    jq "$jq_filter" "$WEBMENU_DB" > "$tmp"
    mv "$tmp" "$WEBMENU_DB"
}

get_entries() {
    jq -c '.entries | sort_by(.name)[]' "$WEBMENU_DB"
}

get_entry_by_name() {
    local name="$1"
    jq -c --arg n "$name" '.entries[] | select(.name == $n)' "$WEBMENU_DB"
}

add_entry_json() {
    local name="$1" url="$2" browser="$3" icon="$4" category="$5" tags="$6"

    apply_json_patch "
        .entries += [{
            name: ¥"$name¥",
            url: ¥"$url¥",
            browser: ¥"$browser¥",
            icon: ¥"$icon¥",
            category: ¥"$category¥",
            tags: (¥"$tags¥" | split(¥",¥") | map(select(. != ¥"¥")))
        }]
        | .entries |= sort_by(.name)
    "
}

remove_entry_json() {
    local name="$1"

    apply_json_patch "
        .entries |= map(select(.name != ¥"$name¥")) | sort_by(.name)
    "
}

###############################################
#              VALIDATIONS                    #
###############################################

fail_if() {
    local condition="$1"
    local message="$2"

    if eval "$condition"; then
        echo "Erreur : $message"
        exit 1
    fi
}

validate_url() {
    local url="$1"
    fail_if '[[ ! "$url" =‾ ^https?:// ]]' "l窶儷RL doit commencer par http:// ou https://"
    fail_if '! echo "$url" | grep -Eq "^https?://[a-zA-Z0-9._-]+(/.*)?$"' "URL invalide"
}

validate_name() {
    local name="$1"
    fail_if '[ -z "$name" ]' "le nom ne peut pas ﾃｪtre vide"
    fail_if '[[ "$name" =‾ [/:*?¥"<>|] ]]' "le nom contient des caractﾃｨres interdits"
}

validate_browser() {
    local browser="$1"
    case "$browser" in
        firefox|firefox-ssb|chromium|chrome|brave|edge|xdg-open) return 0 ;;
        *) echo "Erreur : navigateur inconnu : $browser"; exit 1 ;;
    esac
}

validate_tags() {
    local tags="$1"
    fail_if '[[ ! "$tags" =‾ ^[a-zA-Z0-9,_-]*$ ]]' "tags invalides"
}

validate_icon_file() {
    local icon="$1"
    [ "$icon" = "auto" ] && return 0
    fail_if '[ ! -f "$icon" ]' "fichier icﾃｴne introuvable : $icon"
    fail_if '! file "$icon" | grep -qi image' "le fichier n窶册st pas une image"
}

###############################################
#              ICﾃ年ES                         #
###############################################

try_download_icon() {
    local url="$1"
    local dest="$2"

    if wget -q "$url" -O "$dest"; then
        if file "$dest" | grep -qi 'image'; then
            echo "$dest"
            return 0
        fi
    fi

    rm -f "$dest"
    return 1
}

download_icon() {
    local url="$1"
    local domain icon_file

    domain=$(echo "$url" | sed -E 's‾https?://([^/]+).*‾¥1‾')
    icon_file="$WEBMENU_ICONS/$domain.png"

    # Cache local
    [ -f "$icon_file" ] && { echo "$icon_file"; return; }

    # Essais successifs
    try_download_icon "https://www.google.com/s2/favicons?domain=$domain&sz=64" "$icon_file" && return
    try_download_icon "https://$domain/favicon.ico" "$icon_file" && return
    try_download_icon "https://favicon.im/$domain" "$icon_file" && return

    # Icﾃｴne par dﾃｩfaut
    echo "/usr/share/icons/hicolor/64x64/apps/web-browser.png"
}

###############################################
#              COMMANDES EXEC                 #
###############################################

build_exec_command() {
    local browser="$1" url="$2"
    case "$browser" in
        firefox) echo "firefox --new-window ¥"$url¥"" ;;
        firefox-ssb) echo "firefox --ssb ¥"$url¥"" ;;
        chromium) echo "chromium --app=¥"$url¥"" ;;
        chrome) echo "google-chrome --app=¥"$url¥"" ;;
        brave) echo "brave --app=¥"$url¥"" ;;
        edge) echo "microsoft-edge --app=¥"$url¥"" ;;
        xdg-open|*) echo "xdg-open ¥"$url¥"" ;;
    esac
}

###############################################
#              TEMPLATES                      #
###############################################

apply_template() {
    local template="$1"
    shift
    local content="$template"

    while [ $# -gt 0 ]; do
        local key="$1"
        local value="$2"
        content=$(echo "$content" | sed "s|{{$key}}|$value|g")
        shift 2
    done

    echo "$content"
}

###############################################
#              FICHIERS DESKTOP               #
###############################################

slugify_name() {
    echo "$1" | tr ' ' '_' | tr '[:upper:]' '[:lower:]'
}

generate_desktop_file() {
    local name="$1" url="$2" browser="$3" icon_mode="$4" category="$5"
    local slug file icon_path exec_cmd template

    slug=$(slugify_name "$name")
    file="$WEBMENU_DESKTOP_DIR/$slug.desktop"

    icon_path=$([ "$icon_mode" = "auto" ] && download_icon "$url" || echo "$icon_mode")
    exec_cmd=$(build_exec_command "$browser" "$url")
    template=$(cat "$TEMPLATE_FILE")

    apply_template "$template" ¥
        NAME "$name" ¥
        EXEC "$exec_cmd" ¥
        ICON "$icon_path" ¥
        CATEGORY "$category" ¥
        > "$file"
}

remove_desktop_file() {
    local name="$1"
    local slug file
    slug=$(slugify_name "$name")
    file="$WEBMENU_DESKTOP_DIR/$slug.desktop"
    [ -f "$file" ] && rm "$file"
}

###############################################
#              REFRESH CINNAMON               #
###############################################

refresh_cinnamon() {
    update-desktop-database "$HOME/.local/share/applications" >/dev/null 2>&1 || true
    cinnamon --replace >/dev/null 2>&1 &
}

