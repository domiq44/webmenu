#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'

###############################################
#              CHARGEMENT UTILS               #
###############################################

# Charge toutes les fonctions utilitaires
. "$HOME/.local/bin/webmenu-utils"

# Vérifie les dépendances et charge la configuration
require_deps
load_config

###############################################
#                  USAGE                      #
###############################################

usage() {
    cat <<EOF
WebMenu - Gestionnaire de webapps

Usage :
  webmenu <commande> [options]

Commandes :
  add "Nom" "URL" [--browser B] [--tags t1,t2]
      Ajouter un site web.

  remove "Nom"
      Supprimer un site web.

  list
      Lister les sites enregistrés.

  sync
      Régénérer tous les fichiers .desktop.

  refresh
      Rafraîchir le menu des applications.

  refresh-icons
      Retélécharger toutes les icônes.

  gui
      Lancer l'interface graphique.

  daemon
      Lancer le daemon de synchronisation.

  purge
      Supprimer proprement WebMenu et toutes les entrées qu'il a créées.

Exemples :
  webmenu add "YouTube" "https://youtube.com" --browser firefox-ssb
  webmenu remove "YouTube"
  webmenu list

EOF
}

###############################################
#              PARSING COMMANDE               #
###############################################

cmd="${1:-}"
shift || true

# Si aucune commande → afficher l'aide
if [ -z "$cmd" ]; then
    usage
    exit 1
fi

###############################################
#                ROUTEUR COMMANDES            #
###############################################

case "$cmd" in

    ###########################################
    #                 ADD                     #
    ###########################################
    add)
        name="${1:-}"
        url="${2:-}"
        shift 2 || true

        # Vérification des arguments
        if [ -z "$name" ] || [ -z "$url" ]; then
            usage
            exit 1
        fi

        browser="$DEFAULT_BROWSER"
        tags=""

        # Parsing des options
        while [ $# -gt 0 ]; do
            case "$1" in
                --browser) browser="$2"; shift 2 ;;
                --tags) tags="$2"; shift 2 ;;
                *) shift ;;
            esac
        done

        # Validations
        validate_url "$url"
        validate_name "$name"
        validate_browser "$browser"
        validate_tags "$tags"

        # Ajout dans la base JSON
        add_entry_json "$name" "$url" "$browser" "auto" "Web" "$tags"

        # Création du menu Web si nécessaire
        create_webmenu_category

        # Génération du .desktop
        generate_desktop_file "$name" "$url" "$browser" "auto" "Web"

        refresh_cinnamon
    ;;

    ###########################################
    #             REFRESH ICONS               #
    ###########################################
    refresh-icons)
        rm -f "$WEBMENU_ICONS"/*.png 2>/dev/null || true

        get_entries | while read -r entry; do
            name=$(echo "$entry" | jq -r '.name')
            url=$(echo "$entry" | jq -r '.url')
            browser=$(echo "$entry" | jq -r '.browser')
            category=$(echo "$entry" | jq -r '.category')

            generate_desktop_file "$name" "$url" "$browser" "auto" "$category"
        done

        refresh_cinnamon
    ;;

    ###########################################
    #                REMOVE                   #
    ###########################################
    remove)
        name="${1:-}"

        if [ -z "$name" ]; then
            usage
            exit 1
        fi

        remove_entry_json "$name"
        remove_desktop_file "$name"
        refresh_cinnamon
    ;;

    ###########################################
    #                 LIST                    #
    ###########################################
    list)
        get_entries | jq -r '.name + " -> " + .url'
    ;;

    ###########################################
    #                 SYNC                    #
    ###########################################
    sync)
        # Nettoyage des anciens .desktop
        rm -f "$WEBMENU_DESKTOP_DIR"/*.desktop 2>/dev/null || true

        # Assure la présence du menu Web
        create_webmenu_category

        # Régénération complète
        get_entries | while read -r entry; do
            name=$(echo "$entry" | jq -r '.name')
            url=$(echo "$entry" | jq -r '.url')
            browser=$(echo "$entry" | jq -r '.browser')
            icon=$(echo "$entry" | jq -r '.icon')
            category=$(echo "$entry" | jq -r '.category')

            generate_desktop_file "$name" "$url" "$browser" "$icon" "$category"
        done

        refresh_cinnamon
    ;;

    ###########################################
    #                 PURGE                   #
    ###########################################
    purge)
        echo "⚠️  Cette opération va supprimer WebMenu et toutes les entrées qu'il a créées."
        read -p "Voulez-vous continuer ? (o/N) : " confirm

        if [ "$confirm" != "o" ]; then
            echo "Annulé."
            exit 0
        fi

        echo "🧹 Suppression des fichiers .desktop créés par WebMenu..."
        get_entries | while read -r entry; do
            name=$(echo "$entry" | jq -r '.name')
            slug=$(echo "$name" | tr ' ' '_' | tr '[:upper:]' '[:lower:]')
            file="$WEBMENU_DESKTOP_DIR/$slug.desktop"
            [ -f "$file" ] && rm "$file"
        done

        echo "🧹 Suppression des icônes WebMenu..."
        get_entries | while read -r entry; do
            url=$(echo "$entry" | jq -r '.url')
            domain=$(echo "$url" | sed -E 's~https?://([^/]+).*~\1~')
            icon="$WEBMENU_ICONS/$domain.png"
            [ -f "$icon" ] && rm "$icon"
        done

        echo "🧹 Suppression de la configuration WebMenu..."
        rm -rf "$WEBMENU_CONF_DIR"

        echo "🧹 Suppression des exécutables WebMenu..."
        rm -f "$HOME/.local/bin/webmenu" \
              "$HOME/.local/bin/webmenu-gui" \
              "$HOME/.local/bin/webmenu-daemon" \
              "$HOME/.local/bin/webmenu-utils"

        echo "🔄 Rafraîchissement du menu..."
        update-desktop-database "$HOME/.local/share/applications" >/dev/null 2>&1 || true

        echo "✅ WebMenu a été entièrement supprimé sans toucher aux autres applications."
        exit 0
    ;;

    ###########################################
    #                 GUI                     #
    ###########################################
    gui)
        "$HOME/.local/bin/webmenu-gui"
    ;;

    ###########################################
    #               DAEMON                    #
    ###########################################
    daemon)
        "$HOME/.local/bin/webmenu-daemon"
    ;;

    ###########################################
    #               REFRESH                   #
    ###########################################
    refresh)
        refresh_cinnamon
    ;;

    ###########################################
    #               DEFAULT                   #
    ###########################################
    *)
        usage
        exit 1
    ;;
esac
