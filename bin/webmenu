#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'

. "$HOME/.local/bin/webmenu-utils"

require_deps
load_config

usage() {
    cat <<EOF
WebMenu - CLI

Commandes :
  webmenu add "Nom" "URL" [--browser B] [--tags t1,t2]
  webmenu remove "Nom"
  webmenu list
  webmenu sync
  webmenu gui
  webmenu daemon
  webmenu refresh
  webmenu refresh-icons
EOF
}

cmd="${1:-}"; shift || true
[ -z "$cmd" ] && usage && exit 1

case "$cmd" in
    add)
        name="$1"; url="$2"; shift 2 || true
        [ -z "$name" ] || [ -z "$url" ] && usage

        browser="$DEFAULT_BROWSER"
        tags=""
        while [ $# -gt 0 ]; do
            case "$1" in
                --browser) browser="$2"; shift 2 ;;
                --tags) tags="$2"; shift 2 ;;
                *) shift ;;
            esac
        done

        validate_url "$url"
        validate_name "$name"
        validate_browser "$browser"
        validate_tags "$tags"
        validate_icon_file "$icon_path"

        add_entry_json "$name" "$url" "$browser" "auto" "Web" "$tags"
        generate_desktop_file "$name" "$url" "$browser" "auto" "Web"
        refresh_cinnamon
    ;;

    refresh-icons)
        rm -f "$WEBMENU_ICONS"/*.png
        get_entries | while read -r entry; do
            name=$(echo "$entry" | jq -r '.name')
            url=$(echo "$entry" | jq -r '.url')
            browser=$(echo "$entry" | jq -r '.browser')
            category=$(echo "$entry" | jq -r '.category')
            generate_desktop_file "$name" "$url" "$browser" "auto" "$category"
        done
        refresh_cinnamon
    ;;

    remove)
        name="$1"
        [ -z "$name" ] && usage
        remove_entry_json "$name"
        remove_desktop_file "$name"
        refresh_cinnamon
    ;;

    list)
        get_entries \
            | jq -r '.name + " -> " + .url'
    ;;

    sync)
        rm -f "$WEBMENU_DESKTOP_DIR"/*.desktop 2>/dev/null || true

        get_entries | while read -r entry; do
            name=$(echo "$entry" | jq -r '.name')
            url=$(echo "$entry" | jq -r '.url')
            browser=$(echo "$entry" | jq -r '.browser')
            icon=$(echo "$entry" | jq -r '.icon')
            category=$(echo "$entry" | jq -r '.category')
            generate_desktop_file "$name" "$url" "$browser" "$icon" "$category"
        done

        refresh_cinnamon
    ;;

    gui)
        "$HOME/.local/bin/webmenu-gui"
    ;;

    daemon)
        "$HOME/.local/bin/webmenu-daemon"
    ;;

    refresh)
        refresh_cinnamon
    ;;

    *)
        usage
    ;;
esac

