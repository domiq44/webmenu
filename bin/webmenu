#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'

. "$HOME/.local/bin/webmenu-utils"

require_deps
load_config

usage() {
    cat <<EOF
WebMenu - Gestionnaire de webapps

Usage :
  webmenu <commande> [options]

Commandes :
  add "Nom" "URL" [--browser B] [--tags t1,t2]
      Ajouter un site web.

  remove "Nom"
      Supprimer un site web.

  list
      Lister les sites enregistrÃĐs.

  sync
      RÃĐgÃĐnÃĐrer tous les fichiers .desktop.

  refresh
      RafraÃŪchir le menu des applications.

  refresh-icons
      RetÃĐlÃĐcharger toutes les icÃīnes.

  gui
      Lancer l'interface graphique.

  daemon
      Lancer le daemon de synchronisation.

  purge
      Supprimer proprement WebMenu et toutes les entrÃĐes qu'il a crÃĐÃĐes.

Exemples :
  webmenu add "YouTube" "https://youtube.com" --browser firefox-ssb
  webmenu remove "YouTube"
  webmenu list

EOF
}

cmd="${1:-}"
shift || true

# Si aucune commande â afficher l'aide
if [ -z "$cmd" ]; then
    usage
    exit 1
fi

case "$cmd" in

    add)
        name="${1:-}"
        url="${2:-}"
        shift 2 || true

        if [ -z "$name" ] || [ -z "$url" ]; then
            usage
            exit 1
        fi

        browser="$DEFAULT_BROWSER"
        tags=""

        while [ $# -gt 0 ]; do
            case "$1" in
                --browser) browser="$2"; shift 2 ;;
                --tags) tags="$2"; shift 2 ;;
                *) shift ;;
            esac
        done

        validate_url "$url"
        validate_name "$name"
        validate_browser "$browser"
        validate_tags "$tags"

        add_entry_json "$name" "$url" "$browser" "auto" "Web" "$tags"
        generate_desktop_file "$name" "$url" "$browser" "auto" "Web"
        refresh_cinnamon
    ;;

    refresh-icons)
        rm -f "$WEBMENU_ICONS"/*.png 2>/dev/null || true

        get_entries | while read -r entry; do
            name=$(echo "$entry" | jq -r '.name')
            url=$(echo "$entry" | jq -r '.url')
            browser=$(echo "$entry" | jq -r '.browser')
            category=$(echo "$entry" | jq -r '.category')

            generate_desktop_file "$name" "$url" "$browser" "auto" "$category"
        done

        refresh_cinnamon
    ;;

    remove)
        name="${1:-}"
        if [ -z "$name" ]; then
            usage
            exit 1
        fi

        remove_entry_json "$name"
        remove_desktop_file "$name"
        refresh_cinnamon
    ;;

    list)
        get_entries | jq -r '.name + " -> " + .url'
    ;;

    sync)
        rm -f "$WEBMENU_DESKTOP_DIR"/*.desktop 2>/dev/null || true

        get_entries | while read -r entry; do
            name=$(echo "$entry" | jq -r '.name')
            url=$(echo "$entry" | jq -r '.url')
            browser=$(echo "$entry" | jq -r '.browser')
            icon=$(echo "$entry" | jq -r '.icon')
            category=$(echo "$entry" | jq -r '.category')

            generate_desktop_file "$name" "$url" "$browser" "$icon" "$category"
        done

        refresh_cinnamon
    ;;

    purge)
        echo "â ïļ  Cette opÃĐration va supprimer WebMenu et toutes les entrÃĐes qu'il a crÃĐÃĐes."
        read -p "Voulez-vous continuer ? (o/N) : " confirm

        if [ "$confirm" != "o" ]; then
            echo "AnnulÃĐ."
            exit 0
        fi

        echo "ð§đ Suppression des fichiers .desktop crÃĐÃĐs par WebMenu..."
        get_entries | while read -r entry; do
            name=$(echo "$entry" | jq -r '.name')
            slug=$(echo "$name" | tr ' ' '_' | tr '[:upper:]' '[:lower:]')
            file="$WEBMENU_DESKTOP_DIR/$slug.desktop"
            [ -f "$file" ] && rm "$file"
        done

        echo "ð§đ Suppression des icÃīnes WebMenu..."
        get_entries | while read -r entry; do
            url=$(echo "$entry" | jq -r '.url')
            domain=$(echo "$url" | sed -E 's~https?://([^/]+).*~\1~')
            icon="$WEBMENU_ICONS/$domain.png"
            [ -f "$icon" ] && rm "$icon"
        done

        echo "ð§đ Suppression de la configuration WebMenu..."
        rm -rf "$WEBMENU_CONF_DIR"

        echo "ð§đ Suppression des exÃĐcutables WebMenu..."
        rm -f "$HOME/.local/bin/webmenu" \
              "$HOME/.local/bin/webmenu-gui" \
              "$HOME/.local/bin/webmenu-daemon" \
              "$HOME/.local/bin/webmenu-utils"

        echo "ð RafraÃŪchissement du menu..."
        update-desktop-database "$HOME/.local/share/applications" >/dev/null 2>&1 || true

        echo "â WebMenu a ÃĐtÃĐ entiÃĻrement supprimÃĐ sans toucher aux autres applications."
        exit 0
    ;;

    gui)
        "$HOME/.local/bin/webmenu-gui"
    ;;

    daemon)
        "$HOME/.local/bin/webmenu-daemon"
    ;;

    refresh)
        refresh_cinnamon
    ;;

    *)
        usage
        exit 1
    ;;
esac

